# Application
NODE_ENV=development

# HTTP (api)
HTTP_HOST=0.0.0.0
HTTP_PORT=3000

# PostgreSQL
POSTGRES_URL=postgres://smriti:smriti@localhost:55432/smriti
POSTGRES_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=smriti
KAFKA_GROUP_ID=smriti-workers

# Embedding provider: 'openai' | 'mock'
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
OPENAI_API_KEY=

# LLM provider: 'openai' | 'mock'
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini

# Auth (required when NODE_ENV=production)
API_KEY=

# Rate limiting (api)
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=100

# Worker metrics HTTP port (0 = disabled; set per container in Docker)
WORKER_METRICS_PORT=0

# Scheduler intervals (ms)
SCHEDULE_SUMMARIZE_MS=300000
SCHEDULE_CONSOLIDATE_MS=900000
SCHEDULE_PROFILE_MS=1800000
SCHEDULE_DECAY_MS=3600000
MEMORY_DECAY_FACTOR=0.95
MEMORY_DECAY_AGE_DAYS=7
MEMORY_ARCHIVE_THRESHOLD=0.05
CONSOLIDATION_SIMILARITY_THRESHOLD=0.92

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=smriti
