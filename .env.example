# Application
NODE_ENV=development

# HTTP (api)
HTTP_HOST=0.0.0.0
HTTP_PORT=3000

# PostgreSQL
POSTGRES_URL=postgres://smriti:smriti@localhost:55432/smriti
POSTGRES_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379

# Kafka (local Docker — plaintext)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=smriti
KAFKA_GROUP_ID=smriti-workers

# Kafka (managed e.g. Redpanda Cloud — uncomment and set SASL creds; SSL auto-enables)
# KAFKA_BROKERS=seed-xxxxx.ap-south-1.aws.redpanda.cloud:9092
# KAFKA_SSL=true
# KAFKA_SASL_MECHANISM=scram-sha-256
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# Embedding provider: 'openai' | 'gemini' | 'mock'
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small # For Gemini, use e.g. text-embedding-004
EMBEDDING_DIMENSIONS=1536              # For Gemini text-embedding-004, use 768
OPENAI_API_KEY=
GEMINI_API_KEY=

# LLM provider: 'openai' | 'gemini' | 'mock'
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini                 # For Gemini, use e.g. gemini-1.5-flash or gemini-2.0-flash

# Auth (required when NODE_ENV=production)
API_KEY=

# Rate limiting (api)
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=100

# Worker metrics HTTP port (0 = disabled; set per container in Docker)
WORKER_METRICS_PORT=0

# Scheduler intervals (ms)
SCHEDULE_SUMMARIZE_MS=300000
SCHEDULE_CONSOLIDATE_MS=900000
SCHEDULE_PROFILE_MS=1800000
SCHEDULE_DECAY_MS=3600000
MEMORY_DECAY_FACTOR=0.95
MEMORY_DECAY_AGE_DAYS=7
MEMORY_ARCHIVE_THRESHOLD=0.05
CONSOLIDATION_SIMILARITY_THRESHOLD=0.92

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=smriti
