{
  "name": "@smriti/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "esbuild src/main.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/main.js --packages=external --tsconfig=tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@smriti/auth": "workspace:*",
    "@smriti/config": "workspace:*",
    "@smriti/embedding": "workspace:*",
    "@smriti/kafka": "workspace:*",
    "@smriti/memory-core": "workspace:*",
    "@smriti/observability": "workspace:*",
    "@smriti/postgres": "workspace:*",
    "@smriti/redis": "workspace:*",
    "@smriti/retrieval-core": "workspace:*",
    "@smriti/shared-types": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-fastify": "^10.4.15",
    "@nestjs/throttler": "^6.4.0",
    "fastify": "^4.29.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "nx": {
    "tags": [
      "type:app"
    ]
  }
}
